# Copy to .env and fill in values. Never commit .env.
PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5434/todo_service
# Base64-encoded HMAC secret, >= 32 bytes decoded. Must match auth service.
# Must use standard Base64 (not URL-safe). Generate with:
#   openssl rand 32 | base64
JWT_SECRET=
COOKIE_NAME=token
DB_USERNAME=postgres
DB_PASSWORD=postgres
# Comma-separated list of allowed CORS origins.
CORS_ALLOWED_ORIGINS=https://savuliak.com
